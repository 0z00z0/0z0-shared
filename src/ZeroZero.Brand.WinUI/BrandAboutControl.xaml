<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ZeroZero.Brand.WinUI.BrandAboutControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand typeface: Cascadia Mono, embedded in this library (Assets/Fonts). Grid/StackPanel
         have no FontFamily to inherit from, so it's applied via an implicit TextBlock style
         (covers every TextBlock, including the credit rows added in code-behind) plus an explicit
         BrandFont on each Button's label. Per 0z0-design: Cascadia Mono is the studio's UI/body
         face; Cascadia Code is only for genuine code/terminal surfaces, not this control. -->
    <UserControl.Resources>
        <FontFamily x:Key="BrandFont">ms-appx:///Assets/Fonts/CascadiaMono.ttf#Cascadia Mono</FontFamily>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource BrandFont}"/>
        </Style>
    </UserControl.Resources>

    <StackPanel x:Name="Root">

        <!-- ── Brand header: unified brand navy (not per-app tinted, not theme-adaptive — this is
             fixed studio identity, deliberately not a ThemeResource; see class doc). ──────────── -->
        <Border Padding="16,12,16,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#15263A" Offset="0"/>
                    <GradientStop Color="#0A0F17" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- [Ø] studio mark -->
                <Viewbox Width="72" Height="72" Grid.Column="0" VerticalAlignment="Center">
                    <Canvas Width="256" Height="256">
                        <!-- Background plate: per 0z0-design/logo/GUIDE.md, the studio mark
                             carries its own rounded-square radial-gradient plate wherever the
                             full mark is used (About-box credits is an explicitly named
                             context) — not just the header's own background. -->
                        <Rectangle Width="240" Height="240" Canvas.Left="8" Canvas.Top="8"
                                   RadiusX="52" RadiusY="52">
                            <Rectangle.Fill>
                                <RadialGradientBrush Center="0.5,0.35" RadiusX="0.85" RadiusY="0.85">
                                    <GradientStop Color="#15263A" Offset="0"/>
                                    <GradientStop Color="#0A0F17" Offset="1"/>
                                </RadialGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <!-- Left bracket "[" -->
                        <Path Data="M104,78 H82 V178 H104" StrokeThickness="15"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round">
                            <Path.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#27E0C8" Offset="0"/>
                                    <GradientStop Color="#11A9D6" Offset="1"/>
                                </LinearGradientBrush>
                            </Path.Stroke>
                        </Path>
                        <!-- Right bracket "]" -->
                        <Path Data="M152,78 H174 V178 H152" StrokeThickness="15"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round">
                            <Path.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#7B8CFF" Offset="0"/>
                                    <GradientStop Color="#3F5BE0" Offset="1"/>
                                </LinearGradientBrush>
                            </Path.Stroke>
                        </Path>
                        <!-- "0" of the Ø -->
                        <Rectangle Width="32" Height="80" Canvas.Left="112" Canvas.Top="88"
                                   RadiusX="12" RadiusY="12" Stroke="#D8A657" StrokeThickness="10" Fill="Transparent"/>
                        <!-- Slash of the Ø -->
                        <Line X1="148" Y1="92" X2="108" Y2="164" Stroke="#D8A657" StrokeThickness="6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Viewbox>

                <!-- App name + version -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            Margin="10,0,0,0" Spacing="2">
                    <TextBlock x:Name="AppNameText" Text="App"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock x:Name="VersionText" Text="v—"
                               FontSize="11" Foreground="#80FFFFFF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Body (inherits the host's theme via ThemeResource brushes) ─────────────────── -->
        <StackPanel Padding="16,12,16,16" Spacing="10">

            <!-- Studio wordmark: teal→purple gradient text, clickable through to the studio site. -->
            <Button x:Name="StudioLinkBtn"
                    Background="Transparent" BorderBrush="Transparent"
                    Padding="0" HorizontalAlignment="Left" HorizontalContentAlignment="Left">
                <StackPanel Spacing="2">
                    <TextBlock FontSize="12" FontWeight="SemiBold">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#27E0C8" Offset="0"/>
                                <GradientStop Color="#7B8CFF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        ZeroZero Software
                    </TextBlock>
                    <TextBlock Text="Small tools. Zero bloat."
                               FontSize="10"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </StackPanel>
            </Button>

            <!-- App description -->
            <TextBlock x:Name="DescriptionText"
                FontSize="11" TextWrapping="Wrap"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- Repository | Website | Donate — three co-equal links (no "Check for Updates" here;
                 that's a window-only concern layered on by BrandAboutWindow). -->
            <Grid ColumnSpacing="8" Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="RepoBtn" Grid.Column="0"
                        Content="GitHub"
                        FontSize="11" FontFamily="{StaticResource BrandFont}"
                        HorizontalAlignment="Stretch"/>
                <Button x:Name="SiteBtn" Grid.Column="1"
                        Content="Website"
                        FontSize="11" FontFamily="{StaticResource BrandFont}"
                        HorizontalAlignment="Stretch"/>
                <Button x:Name="DonateBtn" Grid.Column="2"
                        Content="☕ Donate"
                        FontSize="11" FontFamily="{StaticResource BrandFont}"
                        HorizontalAlignment="Stretch"/>
            </Grid>

            <!-- External libraries (collapsed by default; hidden entirely if empty).
                 A plain text toggle rather than a full Expander control — the built-in
                 Expander's card chrome (background, border, full-width header) reads as a
                 prominent action row; local Background/BorderThickness overrides on it don't
                 fully strip that, since the header's own theme-resource brushes still apply.
                 A small link-styled Button is a deliberately low-key credits footnote. -->
            <StackPanel x:Name="LibrariesGroup" Spacing="4">
                <Button x:Name="LibrariesToggleBtn" Click="OnLibrariesToggle"
                        Content="External libraries ▾"
                        FontSize="9" FontFamily="{StaticResource BrandFont}"
                        Padding="0" MinWidth="0" MinHeight="0"
                        Background="Transparent" BorderBrush="Transparent"
                        HorizontalAlignment="Left"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                <StackPanel x:Name="LibrariesPanel" Spacing="6" Padding="0,2,0,0"
                            Visibility="Collapsed"/>
            </StackPanel>

            <!-- Footer -->
            <TextBlock x:Name="FooterText"
                       FontSize="9" Opacity="0.7"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>

        </StackPanel>
    </StackPanel>
</UserControl>
