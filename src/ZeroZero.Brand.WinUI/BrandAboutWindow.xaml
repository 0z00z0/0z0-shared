<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ZeroZero.Brand.WinUI.BrandAboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:brand="using:ZeroZero.Brand.WinUI">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <!-- Thin shell around BrandAboutControl: Mica backdrop, no title bar, sizing/centering/close,
         and the window-only "Check for Updates" action. The About *content* (brand header, links,
         credits) lives in the hosted control so it can also be embedded in a host app's own
         in-navigation page with none of this chrome (see BrandAboutControl's class doc). -->
    <Grid x:Name="Root">
        <Grid.Resources>
            <!-- Own copy of the brand font resource: it doesn't cascade out of the hosted
                 UserControl's resource scope into this window's chrome elements (close/update). -->
            <FontFamily x:Key="BrandFont">ms-appx:///Assets/Fonts/CascadiaMono.ttf#Cascadia Mono</FontFamily>
        </Grid.Resources>

        <StackPanel>
            <brand:BrandAboutControl x:Name="AboutControl"/>

            <!-- Check for Updates: window-only, appended below the hosted control's own body.
                 Padding matches the control's body padding so it reads as one continuous panel. -->
            <StackPanel Padding="16,0,16,16">
                <Button x:Name="UpdateBtn"
                        Content="Check for Updates"
                        FontSize="11" FontFamily="{StaticResource BrandFont}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </StackPanel>

        <!-- Close button: window-only chrome, overlaid on the header band's top-right corner
             (Margin approximates the band's own 16,12,16,12 padding so it lands in the same spot
             the old single-file window used to place it). -->
        <Button x:Name="CloseBtn"
                Content="✕" Width="32" Height="32"
                Padding="0" FontSize="11"
                FontFamily="{StaticResource BrandFont}"
                Background="Transparent"
                BorderBrush="Transparent"
                Foreground="#80FFFFFF"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,12,12,0"/>
    </Grid>
</Window>
